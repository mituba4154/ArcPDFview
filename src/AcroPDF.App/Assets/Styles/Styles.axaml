<Styles xmlns="https://github.com/avaloniaui">
  <Style Selector="Button, ToggleButton">
    <Setter Property="Background" Value="{DynamicResource BgPanelBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="MinHeight" Value="28" />
  </Style>

  <Style Selector="Button:pointerover, ToggleButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource BgPanel2Brush}" />
  </Style>

  <Style Selector="ToggleButton:checked">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Accent2Brush}" />
  </Style>

  <Style Selector="TextBox, ComboBox">
    <Setter Property="Background" Value="{DynamicResource BgPanelBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="MinHeight" Value="28" />
  </Style>

  <Style Selector="Separator">
    <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
  </Style>
</Styles>
