<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AcroPDF.App.Controls"
        x:Class="AcroPDF.App.Views.MainWindow"
        Title="AcroPDF"
        Width="1280"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        Background="{DynamicResource BgDark}"
        DragDrop.AllowDrop="True"
        KeyDown="OnWindowKeyDown"
        PointerWheelChanged="OnWindowPointerWheelChanged">
  <Grid RowDefinitions="36,40,*,22">
    <Border Grid.Row="0"
            Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <Button x:Name="AddTabButton"
                DockPanel.Dock="Right"
                Width="32"
                Margin="4"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{DynamicResource TextPrimaryBrush}"
                Content="+"
                Click="OnAddTabClicked" />
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <StackPanel x:Name="TabHost"
                      Orientation="Horizontal"
                      Margin="6,4" />
        </ScrollViewer>
      </DockPanel>
    </Border>

    <Border Grid.Row="1"
            Background="{DynamicResource BgToolbarBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto"
            Margin="8,4">
        <StackPanel Orientation="Horizontal"
                    Spacing="4">
          <Button x:Name="OpenFileButton"
                  Content="開く"
                  Padding="10,2"
                  Click="OnOpenFileClicked" />
          <Button x:Name="RecentFilesButton"
                  Content="最近"
                  Padding="10,2"
                  Click="OnRecentFilesClicked" />
          <Separator Margin="4,0" />
          <ToggleButton x:Name="HighlightToolButton"
                        Content="🖊"
                        ToolTip.Tip="ハイライトツール"
                        Click="OnHighlightToolClicked" />
          <ToggleButton x:Name="CommentToolButton"
                        Content="💬"
                        ToolTip.Tip="コメントツール"
                        Click="OnCommentToolClicked" />
          <ToggleButton x:Name="FreehandToolButton"
                        Content="✍"
                        ToolTip.Tip="フリーハンドツール"
                        Click="OnFreehandToolClicked" />
          <ToggleButton x:Name="ShapeToolButton"
                        Content="□"
                        ToolTip.Tip="図形ツール"
                        Click="OnShapeToolClicked" />
          <ToggleButton x:Name="StampToolButton"
                        Content="🏷"
                        ToolTip.Tip="スタンプツール"
                        Click="OnStampToolClicked" />
          <ComboBox x:Name="ShapeTypeComboBox"
                    Width="88"
                    SelectedIndex="0"
                    SelectionChanged="OnShapeTypeChanged">
            <ComboBoxItem Content="矩形" />
            <ComboBoxItem Content="楕円" />
            <ComboBoxItem Content="矢印" />
            <ComboBoxItem Content="線" />
          </ComboBox>
          <ComboBox x:Name="StrokeColorComboBox"
                    Width="78"
                    SelectedIndex="0"
                    SelectionChanged="OnStrokeStyleChanged">
            <ComboBoxItem Content="赤" />
            <ComboBoxItem Content="緑" />
            <ComboBoxItem Content="青" />
            <ComboBoxItem Content="黄" />
            <ComboBoxItem Content="黒" />
          </ComboBox>
          <ComboBox x:Name="FillColorComboBox"
                    Width="78"
                    SelectedIndex="0"
                    SelectionChanged="OnStrokeStyleChanged">
            <ComboBoxItem Content="なし" />
            <ComboBoxItem Content="赤" />
            <ComboBoxItem Content="緑" />
            <ComboBoxItem Content="青" />
            <ComboBoxItem Content="黄" />
          </ComboBox>
          <ComboBox x:Name="StrokeWidthComboBox"
                    Width="72"
                    SelectedIndex="1"
                    SelectionChanged="OnStrokeStyleChanged">
            <ComboBoxItem Content="1px" />
            <ComboBoxItem Content="2px" />
            <ComboBoxItem Content="3px" />
            <ComboBoxItem Content="4px" />
            <ComboBoxItem Content="6px" />
          </ComboBox>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="4">
          <Button Content="⟨⟨"
                  Width="30"
                  Click="OnFirstPageClicked" />
          <Button Content="⟨"
                  Width="30"
                  Click="OnPreviousPageClicked" />
          <TextBox x:Name="PageNumberTextBox"
                   Width="56"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   KeyDown="OnPageNumberTextBoxKeyDown" />
          <TextBlock x:Name="TotalPageTextBlock"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     Text="/ 0" />
          <Button Content="⟩"
                  Width="30"
                  Click="OnNextPageClicked" />
          <Button Content="⟩⟩"
                  Width="30"
                  Click="OnLastPageClicked" />
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="4">
          <Button Content="−"
                  Width="30"
                  Click="OnZoomOutClicked" />
          <ComboBox x:Name="ZoomComboBox"
                    Width="140"
                    SelectionChanged="OnZoomComboBoxSelectionChanged">
            <ComboBoxItem Content="25%" />
            <ComboBoxItem Content="50%" />
            <ComboBoxItem Content="75%" />
            <ComboBoxItem Content="100%" />
            <ComboBoxItem Content="125%" />
            <ComboBoxItem Content="150%" />
            <ComboBoxItem Content="200%" />
            <ComboBoxItem Content="300%" />
            <ComboBoxItem Content="400%" />
            <ComboBoxItem Content="幅に合わせる" />
            <ComboBoxItem Content="ページに合わせる" />
            <ComboBoxItem Content="実寸" />
          </ComboBox>
          <Button Content="+"
                  Width="30"
                  Click="OnZoomInClicked" />
        </StackPanel>

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    Margin="8,0,0,0"
                    Spacing="4">
          <ToggleButton x:Name="SinglePageModeButton"
                        Content="▣ 単ページ"
                        Click="OnSinglePageModeClicked" />
          <ToggleButton x:Name="ContinuousModeButton"
                        Content="⊟ 連続"
                        Click="OnContinuousModeClicked" />
          <ToggleButton x:Name="TwoPageModeButton"
                        Content="▥ 見開き"
                        Click="OnTwoPageModeClicked" />
          <ToggleButton x:Name="SplitViewModeButton"
                        Content="⊞ 分割"
                        Click="OnSplitViewModeClicked" />
          <Button x:Name="RotateButton"
                  Content="⟳ 回転"
                  Click="OnRotateClicked" />
          <Button x:Name="PrintButton"
                  Content="🖨 印刷"
                  Click="OnPrintClicked" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="2"
          ColumnDefinitions="220,*,240"
          Background="{DynamicResource BgDarkBrush}">
      <Border Grid.Column="0"
              Background="{DynamicResource BgPanelBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="0,0,1,0">
          <TabControl x:Name="LeftSidebarTabControl">
          <TabItem Header="サムネイル">
            <ScrollViewer x:Name="ThumbnailScrollViewer"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel x:Name="ThumbnailPanel"
                          Margin="8"
                          Spacing="8" />
            </ScrollViewer>
          </TabItem>
          <TabItem Header="目次">
            <ScrollViewer x:Name="BookmarkScrollViewer"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel x:Name="BookmarkPanel"
                          Margin="8"
                          Spacing="2" />
            </ScrollViewer>
          </TabItem>
          </TabControl>
      </Border>

      <Grid Grid.Column="1">
        <TextBlock x:Name="EmptyStateTextBlock"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Text="PDF をドラッグ&amp;ドロップするか、[開く] ボタンから選択してください。" />
        <ScrollViewer x:Name="SinglePageScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
          <Grid HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="16">
            <controls:PdfPageControl x:Name="PageControl"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Top"
                                      PointerMoved="OnSinglePagePointerMoved"
                                      PointerPressed="OnSinglePagePointerPressed"
                                      PointerReleased="OnSinglePagePointerReleased" />
            <Canvas x:Name="AnnotationOverlayCanvas"
                    IsHitTestVisible="True" />
          </Grid>
        </ScrollViewer>
        <ScrollViewer x:Name="ContinuousScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      ScrollChanged="OnContinuousScrollViewerScrollChanged"
                      IsVisible="False">
          <ItemsControl x:Name="ContinuousPageItemsControl"
                        Margin="16"
                        HorizontalAlignment="Center">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </ScrollViewer>
        <Grid x:Name="SplitViewGrid"
              IsVisible="False"
              ColumnDefinitions="*,3,*"
              MinWidth="280">
          <Border Grid.Column="0"
                  Margin="8"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1">
            <DockPanel>
              <ComboBox x:Name="PrimarySplitTabComboBox"
                        DockPanel.Dock="Top"
                        Margin="8"
                        SelectionChanged="OnPrimarySplitTabSelectionChanged" />
              <ScrollViewer x:Name="PrimarySplitScrollViewer"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                <controls:PdfPageControl x:Name="PrimarySplitPageControl"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Top"
                                          Margin="16"
                                          PointerPressed="OnPrimarySplitPagePointerPressed" />
              </ScrollViewer>
            </DockPanel>
          </Border>
          <Border x:Name="SplitDivider"
                  Grid.Column="1"
                  Width="3"
                  Background="{DynamicResource BorderLightBrush}"
                  PointerEntered="OnSplitDividerPointerEntered"
                  PointerExited="OnSplitDividerPointerExited"
                  PointerPressed="OnSplitDividerPointerPressed"
                  PointerMoved="OnSplitDividerPointerMoved"
                  PointerReleased="OnSplitDividerPointerReleased" />
          <Border Grid.Column="2"
                  Margin="8"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1">
            <DockPanel>
              <ComboBox x:Name="SecondarySplitTabComboBox"
                        DockPanel.Dock="Top"
                        Margin="8"
                        SelectionChanged="OnSecondarySplitTabSelectionChanged" />
              <ScrollViewer x:Name="SecondarySplitScrollViewer"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                <controls:PdfPageControl x:Name="SecondarySplitPageControl"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Top"
                                          Margin="16"
                                          PointerPressed="OnSecondarySplitPagePointerPressed" />
              </ScrollViewer>
            </DockPanel>
          </Border>
        </Grid>
        <Border x:Name="SearchOverlay"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,12,12,0"
                Background="{DynamicResource BgPanel2Brush}"
                BorderBrush="{DynamicResource BorderLightBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8"
                IsVisible="False">
          <StackPanel Spacing="6">
            <StackPanel Orientation="Horizontal"
                        Spacing="6">
              <TextBox x:Name="SearchTextBox"
                       Width="200"
                       Watermark="検索"
                       TextChanged="OnSearchTextChanged" />
              <TextBlock x:Name="SearchCountTextBlock"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Text="0/0件" />
              <Button Content="∧"
                      Width="26"
                      Click="OnSearchPreviousClicked" />
              <Button Content="∨"
                      Width="26"
                      Click="OnSearchNextClicked" />
              <Button Content="×"
                      Width="26"
                      Click="OnSearchCloseClicked" />
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        Spacing="12">
              <CheckBox x:Name="CaseSensitiveSearchCheckBox"
                        Content="Aa"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Click="OnSearchOptionChanged" />
              <CheckBox x:Name="RegexSearchCheckBox"
                        Content=".*"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Click="OnSearchOptionChanged" />
            </StackPanel>
          </StackPanel>
        </Border>
        <Border x:Name="FloatingAnnotationToolbar"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,16"
                Background="{DynamicResource BgPanel2Brush}"
                BorderBrush="{DynamicResource BorderLightBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="8,6"
                IsVisible="False">
          <StackPanel Orientation="Horizontal"
                      Spacing="6">
            <Button Content="ハイライト"
                    Click="OnFloatingHighlightClicked" />
            <Button Content="下線"
                    Click="OnFloatingUnderlineClicked" />
            <Button Content="取り消し線"
                    Click="OnFloatingStrikeClicked" />
            <Button Content="コメント"
                    Click="OnFloatingCommentClicked" />
            <Button Content="手書き"
                    Click="OnFloatingFreehandClicked" />
            <Button Content="矩形"
                    Click="OnFloatingRectangleClicked" />
            <Button Content="楕円"
                    Click="OnFloatingEllipseClicked" />
            <Button Content="矢印"
                    Click="OnFloatingArrowClicked" />
            <Button Content="スタンプ"
                    Click="OnFloatingStampClicked" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Column="2"
              Background="{DynamicResource BgPanelBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1,0,0,0">
        <Grid RowDefinitions="Auto,*,Auto,Auto"
              Margin="8">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock Text="注釈パネル"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
            <Border Background="{DynamicResource AccentBrush}"
                    CornerRadius="10"
                    Padding="6,2">
              <TextBlock x:Name="AnnotationCountBadgeTextBlock"
                         Foreground="White"
                         FontSize="11"
                         Text="0" />
            </Border>
          </StackPanel>
          <ListBox x:Name="AnnotationPanelListBox"
                   Grid.Row="1"
                   Margin="0,8,0,8"
                   SelectionChanged="OnAnnotationPanelSelectionChanged" />
          <StackPanel Grid.Row="2"
                      Orientation="Horizontal"
                      Spacing="6">
            <Button x:Name="DeleteAnnotationButton"
                    Content="削除"
                    Click="OnDeleteAnnotationClicked" />
            <Button x:Name="ExportFdfButton"
                    Content="FDF エクスポート"
                    Click="OnExportFdfClicked" />
            <Button x:Name="ImportFdfButton"
                    Content="FDF インポート"
                    Click="OnImportFdfClicked" />
          </StackPanel>
          <StackPanel Grid.Row="3"
                      Margin="0,10,0,0"
                      Spacing="2">
            <TextBlock Text="ファイル情報"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock x:Name="FileInfoTextBlock"
                       Foreground="{DynamicResource TextDimBrush}" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="3"
            Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0">
      <Grid Margin="8,2"
            ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*">
        <TextBlock x:Name="ReadyStatusTextBlock"
                   Foreground="{DynamicResource AccentBrush}"
                   Text="● 準備完了" />
        <TextBlock x:Name="FileStatusTextBlock"
                   Grid.Column="1"
                   Margin="12,0,0,0"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock x:Name="PageStatusTextBlock"
                   Grid.Column="2"
                   Margin="12,0,0,0"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock x:Name="ZoomStatusTextBlock"
                   Grid.Column="3"
                   Margin="12,0,0,0"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock x:Name="MouseStatusTextBlock"
                   Grid.Column="4"
                   Margin="12,0,0,0"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock x:Name="PlatformStatusTextBlock"
                   Grid.Column="5"
                   HorizontalAlignment="Right"
                   Foreground="{DynamicResource TextDimBrush}" />
      </Grid>
    </Border>
  </Grid>
</Window>
