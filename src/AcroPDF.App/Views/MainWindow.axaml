<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AcroPDF.App.Controls"
        xmlns:automation="clr-namespace:Avalonia.Automation;assembly=Avalonia.Controls"
        x:Class="AcroPDF.App.Views.MainWindow"
        Title="AcroPDF"
        Width="1280"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        Background="{DynamicResource BgDark}"
        DragDrop.AllowDrop="True"
        KeyDown="OnWindowKeyDown"
        PointerWheelChanged="OnWindowPointerWheelChanged">
  <Window.Styles>
    <Style Selector="Button, ToggleButton, TabItem">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button:focus-visible, ToggleButton:focus-visible, TextBox:focus-visible, ComboBox:focus-visible, CheckBox:focus-visible, TabItem:focus-visible, ListBoxItem:focus-visible">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
  </Window.Styles>
  <Grid RowDefinitions="Auto,36,Auto,*,22"
        KeyboardNavigation.TabNavigation="Cycle">
    <Menu Grid.Row="0"
          Background="{DynamicResource BgDarkBrush}"
          Foreground="{DynamicResource TextPrimaryBrush}">
      <MenuItem x:Name="FileMenuItem" Header="ファイル">
        <MenuItem x:Name="FileOpenMenuItem" Header="開く..." Click="OnOpenFileClicked" />
        <MenuItem x:Name="FileRecentMenuItem" Header="最近" SubmenuOpened="OnRecentFilesMenuOpened" />
        <Separator />
        <MenuItem x:Name="FileSaveMenuItem" Header="保存" Click="OnSaveMenuItemClicked" />
        <MenuItem x:Name="FilePrintMenuItem" Header="印刷..." Click="OnPrintClicked" />
        <Separator />
        <MenuItem x:Name="FileExitMenuItem" Header="終了" Click="OnExitMenuItemClicked" />
      </MenuItem>
      <MenuItem x:Name="EditMenuItem" Header="編集" />
      <MenuItem x:Name="ViewMenuItem" Header="表示">
        <MenuItem x:Name="ViewSinglePageMenuItem" Header="単ページ" Click="OnSinglePageModeClicked" />
        <MenuItem x:Name="ViewContinuousMenuItem" Header="連続" Click="OnContinuousModeClicked" />
        <MenuItem x:Name="ViewTwoPageMenuItem" Header="見開き" Click="OnTwoPageModeClicked" />
        <Separator />
        <MenuItem x:Name="ViewZoomInMenuItem" Header="ズームイン" Click="OnZoomInClicked" />
        <MenuItem x:Name="ViewZoomOutMenuItem" Header="ズームアウト" Click="OnZoomOutClicked" />
        <Separator />
        <MenuItem x:Name="ViewThemeMenuItem" Header="テーマ" Click="OnSettingsClicked" />
      </MenuItem>
      <MenuItem x:Name="ToolsMenuItem" Header="ツール">
        <MenuItem x:Name="ToolsSettingsMenuItem" Header="設定" Click="OnSettingsClicked" />
      </MenuItem>
      <MenuItem x:Name="AnnotationMenuItem" Header="注釈" />
      <MenuItem x:Name="WindowMenuItem" Header="ウィンドウ" />
      <MenuItem x:Name="HelpMenuItem" Header="ヘルプ">
        <MenuItem x:Name="HelpAboutMenuItem" Header="バージョン情報" Click="OnAboutMenuItemClicked" />
      </MenuItem>
    </Menu>

    <Border Grid.Row="1"
            Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <Button x:Name="AddTabButton"
                DockPanel.Dock="Right"
                Width="32"
                Margin="4"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{DynamicResource TextPrimaryBrush}"
                Content="+"
                automation:AutomationProperties.Name="タブ追加"
                Click="OnAddTabClicked" />
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <StackPanel x:Name="TabHost"
                      Orientation="Horizontal"
                      Margin="6,4" />
        </ScrollViewer>
      </DockPanel>
    </Border>

    <Border Grid.Row="2"
            Background="{DynamicResource BgToolbarBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Horizontal"
                    Margin="8,4"
                    Spacing="14">
        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <Button x:Name="OpenFileButton"
                  Content="開く"
                  Padding="10,2"
                  automation:AutomationProperties.Name="PDFファイルを開く"
                  Click="OnOpenFileClicked" />
          <Button x:Name="RecentFilesButton"
                  Content="最近"
                  Padding="10,2"
                  automation:AutomationProperties.Name="最近開いたファイル"
                  Click="OnRecentFilesClicked" />
          <Separator Margin="4,0" />
           <ToggleButton x:Name="HighlightToolButton"
                         MinWidth="36"
                         automation:AutomationProperties.Name="ハイライトツール"
                         ToolTip.Tip="ハイライトツール"
                         Click="OnHighlightToolClicked">
             <StackPanel Spacing="0">
               <TextBlock Text="🖊" HorizontalAlignment="Center" />
               <TextBlock x:Name="HighlightToolLabelTextBlock" FontSize="9" HorizontalAlignment="Center" Text="ハイライト" />
             </StackPanel>
           </ToggleButton>
           <ToggleButton x:Name="CommentToolButton"
                         MinWidth="36"
                         automation:AutomationProperties.Name="コメントツール"
                         ToolTip.Tip="コメントツール"
                         Click="OnCommentToolClicked">
             <StackPanel Spacing="0">
               <TextBlock Text="💬" HorizontalAlignment="Center" />
               <TextBlock x:Name="CommentToolLabelTextBlock" FontSize="9" HorizontalAlignment="Center" Text="コメント" />
             </StackPanel>
           </ToggleButton>
           <ToggleButton x:Name="FreehandToolButton"
                         MinWidth="36"
                         automation:AutomationProperties.Name="フリーハンドツール"
                         ToolTip.Tip="フリーハンドツール"
                         Click="OnFreehandToolClicked">
             <StackPanel Spacing="0">
               <TextBlock Text="✍" HorizontalAlignment="Center" />
               <TextBlock x:Name="FreehandToolLabelTextBlock" FontSize="9" HorizontalAlignment="Center" Text="手書き" />
             </StackPanel>
           </ToggleButton>
           <ToggleButton x:Name="ShapeToolButton"
                         MinWidth="36"
                         automation:AutomationProperties.Name="図形ツール"
                         ToolTip.Tip="図形ツール"
                         Click="OnShapeToolClicked">
             <StackPanel Spacing="0">
               <TextBlock Text="□" HorizontalAlignment="Center" />
               <TextBlock x:Name="ShapeToolLabelTextBlock" FontSize="9" HorizontalAlignment="Center" Text="図形" />
             </StackPanel>
           </ToggleButton>
           <ToggleButton x:Name="StampToolButton"
                         MinWidth="36"
                         automation:AutomationProperties.Name="スタンプツール"
                         ToolTip.Tip="スタンプツール"
                         Click="OnStampToolClicked">
             <StackPanel Spacing="0">
               <TextBlock Text="🏷" HorizontalAlignment="Center" />
               <TextBlock x:Name="StampToolLabelTextBlock" FontSize="9" HorizontalAlignment="Center" Text="スタンプ" />
             </StackPanel>
           </ToggleButton>
          <ComboBox x:Name="ShapeTypeComboBox"
                    Width="88"
                    SelectedIndex="0"
                    automation:AutomationProperties.Name="図形種別"
                    SelectionChanged="OnShapeTypeChanged">
            <ComboBoxItem Content="矩形" />
            <ComboBoxItem Content="楕円" />
            <ComboBoxItem Content="矢印" />
            <ComboBoxItem Content="線" />
          </ComboBox>
          <ComboBox x:Name="StrokeColorComboBox"
                    Width="78"
                    SelectedIndex="0"
                    automation:AutomationProperties.Name="線色"
                    SelectionChanged="OnStrokeStyleChanged">
            <ComboBoxItem Content="赤" />
            <ComboBoxItem Content="緑" />
            <ComboBoxItem Content="青" />
            <ComboBoxItem Content="黄" />
            <ComboBoxItem Content="黒" />
          </ComboBox>
          <ComboBox x:Name="FillColorComboBox"
                    Width="78"
                    SelectedIndex="0"
                    automation:AutomationProperties.Name="塗り色"
                    SelectionChanged="OnStrokeStyleChanged">
            <ComboBoxItem Content="なし" />
            <ComboBoxItem Content="赤" />
            <ComboBoxItem Content="緑" />
            <ComboBoxItem Content="青" />
            <ComboBoxItem Content="黄" />
          </ComboBox>
          <ComboBox x:Name="StrokeWidthComboBox"
                    Width="72"
                    SelectedIndex="1"
                    automation:AutomationProperties.Name="線幅"
                    SelectionChanged="OnStrokeStyleChanged">
            <ComboBoxItem Content="1px" />
            <ComboBoxItem Content="2px" />
            <ComboBoxItem Content="3px" />
            <ComboBoxItem Content="4px" />
            <ComboBoxItem Content="6px" />
          </ComboBox>
        </StackPanel>

        <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <Button Content="⟨⟨"
                  Width="30"
                  automation:AutomationProperties.Name="先頭ページへ移動"
                  Click="OnFirstPageClicked" />
          <Button Content="⟨"
                  Width="30"
                  automation:AutomationProperties.Name="前のページへ移動"
                  Click="OnPreviousPageClicked" />
          <TextBox x:Name="PageNumberTextBox"
                   Width="56"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   automation:AutomationProperties.Name="ページ番号入力"
                   KeyDown="OnPageNumberTextBoxKeyDown" />
          <TextBlock x:Name="TotalPageTextBlock"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     Text="/ 0" />
          <Button Content="⟩"
                  Width="30"
                  automation:AutomationProperties.Name="次のページへ移動"
                  Click="OnNextPageClicked" />
          <Button Content="⟩⟩"
                  Width="30"
                  automation:AutomationProperties.Name="最終ページへ移動"
                  Click="OnLastPageClicked" />
        </StackPanel>

        <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <Button Content="−"
                  Width="30"
                  automation:AutomationProperties.Name="ズームアウト"
                  Click="OnZoomOutClicked" />
          <ComboBox x:Name="ZoomComboBox"
                    Width="140"
                    automation:AutomationProperties.Name="ズーム倍率"
                    SelectionChanged="OnZoomComboBoxSelectionChanged">
            <ComboBoxItem Content="25%" />
            <ComboBoxItem Content="50%" />
            <ComboBoxItem Content="75%" />
            <ComboBoxItem Content="100%" />
            <ComboBoxItem Content="125%" />
            <ComboBoxItem Content="150%" />
            <ComboBoxItem Content="200%" />
            <ComboBoxItem Content="300%" />
            <ComboBoxItem Content="400%" />
            <ComboBoxItem Content="幅に合わせる" />
            <ComboBoxItem Content="ページに合わせる" />
            <ComboBoxItem Content="実寸" />
          </ComboBox>
          <Button Content="+"
                  Width="30"
                  automation:AutomationProperties.Name="ズームイン"
                  Click="OnZoomInClicked" />
        </StackPanel>

        <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <ToggleButton x:Name="SinglePageModeButton"
                        Content="▣ 単ページ"
                        automation:AutomationProperties.Name="単ページモード"
                        Click="OnSinglePageModeClicked" />
          <ToggleButton x:Name="ContinuousModeButton"
                        Content="⊟ 連続"
                        automation:AutomationProperties.Name="連続表示モード"
                        Click="OnContinuousModeClicked" />
          <ToggleButton x:Name="TwoPageModeButton"
                        Content="▥ 見開き"
                        automation:AutomationProperties.Name="見開きモード"
                        Click="OnTwoPageModeClicked" />
          <ToggleButton x:Name="SplitViewModeButton"
                        Content="⊞ 分割"
                        automation:AutomationProperties.Name="分割表示モード"
                        Click="OnSplitViewModeClicked" />
          <Button x:Name="RotateButton"
                  Content="⟳ 回転"
                  automation:AutomationProperties.Name="ページ回転"
                  Click="OnRotateClicked" />
          <Button x:Name="PrintButton"
                  Content="🖨 印刷"
                  automation:AutomationProperties.Name="印刷"
                  Click="OnPrintClicked" />
          <Button x:Name="SettingsButton"
                  Content="設定"
                  automation:AutomationProperties.Name="表示設定を開く"
                  Click="OnSettingsClicked" />
        </StackPanel>
      </StackPanel>
      </ScrollViewer>
    </Border>

    <Grid Grid.Row="3"
          ColumnDefinitions="220,*,240"
          Background="{DynamicResource BgDarkBrush}">
      <Border Grid.Column="0"
              Background="{DynamicResource BgPanelBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="0,0,1,0">
          <TabControl x:Name="LeftSidebarTabControl"
                      automation:AutomationProperties.Name="左サイドバータブ">
          <TabItem>
            <TabItem.Header>
              <StackPanel Orientation="Vertical" Spacing="0">
                <TextBlock Text="▤" HorizontalAlignment="Center" />
                <TextBlock x:Name="ThumbnailTabLabelTextBlock" FontSize="9" Text="サムネ" HorizontalAlignment="Center" />
              </StackPanel>
            </TabItem.Header>
            <ScrollViewer x:Name="ThumbnailScrollViewer"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel x:Name="ThumbnailPanel"
                          Margin="8"
                          Spacing="8" />
            </ScrollViewer>
          </TabItem>
          <TabItem>
            <TabItem.Header>
              <StackPanel Orientation="Vertical" Spacing="0">
                <TextBlock Text="≡" HorizontalAlignment="Center" />
                <TextBlock x:Name="BookmarkTabLabelTextBlock" FontSize="9" Text="目次" HorizontalAlignment="Center" />
              </StackPanel>
            </TabItem.Header>
            <ScrollViewer x:Name="BookmarkScrollViewer"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel x:Name="BookmarkPanel"
                          Margin="8"
                          Spacing="2" />
            </ScrollViewer>
          </TabItem>
          <TabItem>
            <TabItem.Header>
              <StackPanel Orientation="Vertical" Spacing="0">
                <TextBlock Text="💬" HorizontalAlignment="Center" />
                <TextBlock x:Name="AnnotationTabLabelTextBlock" FontSize="9" Text="注釈" HorizontalAlignment="Center" />
              </StackPanel>
            </TabItem.Header>
            <Grid RowDefinitions="Auto,*,Auto"
                  Margin="8">
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <TextBlock Text="注釈"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <Border Background="{DynamicResource AccentBrush}"
                        CornerRadius="10"
                        Padding="6,2">
                  <TextBlock x:Name="AnnotationCountBadgeTextBlock"
                             Foreground="White"
                             FontSize="11"
                             Text="0" />
                </Border>
              </StackPanel>
              <ListBox x:Name="AnnotationPanelListBox"
                       Grid.Row="1"
                       Margin="0,8,0,8"
                       automation:AutomationProperties.Name="注釈カード一覧"
                       SelectionChanged="OnAnnotationPanelSelectionChanged" />
              <StackPanel Grid.Row="2"
                          Orientation="Horizontal"
                          Spacing="6">
                <Button x:Name="DeleteAnnotationButton"
                        Content="削除"
                        automation:AutomationProperties.Name="選択した注釈を削除"
                        Click="OnDeleteAnnotationClicked" />
                <Button x:Name="ExportFdfButton"
                        Content="FDF エクスポート"
                        automation:AutomationProperties.Name="注釈をFDFで書き出し"
                        Click="OnExportFdfClicked" />
                <Button x:Name="ImportFdfButton"
                        Content="FDF インポート"
                        automation:AutomationProperties.Name="注釈をFDFから読み込み"
                        Click="OnImportFdfClicked" />
              </StackPanel>
            </Grid>
          </TabItem>
          <TabItem>
            <TabItem.Header>
              <StackPanel Orientation="Vertical" Spacing="0">
                <TextBlock Text="🔗" HorizontalAlignment="Center" />
                <TextBlock x:Name="AttachmentTabLabelTextBlock" FontSize="9" Text="添付" HorizontalAlignment="Center" />
              </StackPanel>
            </TabItem.Header>
            <DockPanel Margin="8">
               <Button x:Name="ExtractAttachmentButton"
                       DockPanel.Dock="Bottom"
                       Margin="0,8,0,0"
                       Content="保存"
                       IsEnabled="False"
                       automation:AutomationProperties.Name="添付ファイルを保存"
                       Click="OnExtractAttachmentClicked" />
               <ListBox x:Name="AttachmentListBox"
                        automation:AutomationProperties.Name="添付ファイル一覧"
                        SelectionChanged="OnAttachmentSelectionChanged" />
            </DockPanel>
          </TabItem>
          </TabControl>
      </Border>

      <Grid Grid.Column="1">
        <TextBlock x:Name="EmptyStateTextBlock"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Text="PDF をドラッグ&amp;ドロップするか、[開く] ボタンから選択してください。" />
        <ScrollViewer x:Name="SinglePageScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
          <Grid HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="16">
            <controls:PdfPageControl x:Name="PageControl"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Top"
                                      automation:AutomationProperties.Name="PDFページビュー"
                                      PointerMoved="OnSinglePagePointerMoved"
                                      PointerPressed="OnSinglePagePointerPressed"
                                      PointerReleased="OnSinglePagePointerReleased" />
            <Canvas x:Name="AnnotationOverlayCanvas"
                    IsHitTestVisible="True" />
          </Grid>
        </ScrollViewer>
        <ScrollViewer x:Name="ContinuousScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      ScrollChanged="OnContinuousScrollViewerScrollChanged"
                      IsVisible="False">
          <ItemsControl x:Name="ContinuousPageItemsControl"
                        Margin="16"
                        HorizontalAlignment="Left">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </ScrollViewer>
        <Grid x:Name="SplitViewGrid"
              IsVisible="False"
              ColumnDefinitions="*,3,*"
              MinWidth="280">
          <Border Grid.Column="0"
                  Margin="8"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1">
            <DockPanel>
              <ComboBox x:Name="PrimarySplitTabComboBox"
                        DockPanel.Dock="Top"
                        Margin="8"
                        automation:AutomationProperties.Name="左ペインのタブ選択"
                        SelectionChanged="OnPrimarySplitTabSelectionChanged" />
              <ScrollViewer x:Name="PrimarySplitScrollViewer"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                <controls:PdfPageControl x:Name="PrimarySplitPageControl"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top"
                                          Margin="16"
                                          PointerPressed="OnPrimarySplitPagePointerPressed" />
              </ScrollViewer>
            </DockPanel>
          </Border>
          <Border x:Name="SplitDivider"
                  Grid.Column="1"
                  Width="3"
                  Background="{DynamicResource BorderLightBrush}"
                  PointerEntered="OnSplitDividerPointerEntered"
                  PointerExited="OnSplitDividerPointerExited"
                  PointerPressed="OnSplitDividerPointerPressed"
                  PointerMoved="OnSplitDividerPointerMoved"
                  PointerReleased="OnSplitDividerPointerReleased" />
          <Border Grid.Column="2"
                  Margin="8"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1">
            <DockPanel>
              <ComboBox x:Name="SecondarySplitTabComboBox"
                        DockPanel.Dock="Top"
                        Margin="8"
                        automation:AutomationProperties.Name="右ペインのタブ選択"
                        SelectionChanged="OnSecondarySplitTabSelectionChanged" />
              <ScrollViewer x:Name="SecondarySplitScrollViewer"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                <controls:PdfPageControl x:Name="SecondarySplitPageControl"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top"
                                          Margin="16"
                                          PointerPressed="OnSecondarySplitPagePointerPressed" />
              </ScrollViewer>
            </DockPanel>
          </Border>
        </Grid>
        <Border x:Name="SearchOverlay"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,12,12,0"
                Background="{DynamicResource BgPanel2Brush}"
                BorderBrush="{DynamicResource BorderLightBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8"
                IsVisible="False">
          <StackPanel Spacing="6">
            <StackPanel Orientation="Horizontal"
                        Spacing="6">
              <TextBox x:Name="SearchTextBox"
                       Width="200"
                       Watermark="検索"
                       automation:AutomationProperties.Name="検索キーワード"
                       TextChanged="OnSearchTextChanged" />
              <TextBlock x:Name="SearchCountTextBlock"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Text="0/0件" />
              <Button Content="∧"
                      Width="26"
                      automation:AutomationProperties.Name="前の検索結果"
                      Click="OnSearchPreviousClicked" />
              <Button Content="∨"
                      Width="26"
                      automation:AutomationProperties.Name="次の検索結果"
                      Click="OnSearchNextClicked" />
              <Button Content="×"
                      Width="26"
                      automation:AutomationProperties.Name="検索を閉じる"
                      Click="OnSearchCloseClicked" />
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        Spacing="12">
              <CheckBox x:Name="CaseSensitiveSearchCheckBox"
                        Content="Aa"
                        automation:AutomationProperties.Name="大文字小文字を区別"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Click="OnSearchOptionChanged" />
              <CheckBox x:Name="RegexSearchCheckBox"
                        Content=".*"
                        automation:AutomationProperties.Name="正規表現検索"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Click="OnSearchOptionChanged" />
            </StackPanel>
          </StackPanel>
        </Border>
        <Border x:Name="FloatingAnnotationToolbar"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,16"
                Background="{DynamicResource BgPanel2Brush}"
                BorderBrush="{DynamicResource BorderLightBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="8,6"
                IsVisible="False">
          <StackPanel Orientation="Horizontal"
                      Spacing="6">
            <Button Content="ハイライト"
                    automation:AutomationProperties.Name="選択範囲をハイライト"
                    Click="OnFloatingHighlightClicked" />
            <Button Content="下線"
                    automation:AutomationProperties.Name="選択範囲に下線"
                    Click="OnFloatingUnderlineClicked" />
            <Button Content="取り消し線"
                    automation:AutomationProperties.Name="選択範囲に取り消し線"
                    Click="OnFloatingStrikeClicked" />
            <Button Content="コメント"
                    automation:AutomationProperties.Name="コメント注釈を追加"
                    Click="OnFloatingCommentClicked" />
            <Button Content="手書き"
                    automation:AutomationProperties.Name="手書き注釈モード"
                    Click="OnFloatingFreehandClicked" />
            <Button Content="矩形"
                    automation:AutomationProperties.Name="矩形注釈を追加"
                    Click="OnFloatingRectangleClicked" />
            <Button Content="楕円"
                    automation:AutomationProperties.Name="楕円注釈を追加"
                    Click="OnFloatingEllipseClicked" />
            <Button Content="矢印"
                    automation:AutomationProperties.Name="矢印注釈を追加"
                    Click="OnFloatingArrowClicked" />
            <Button Content="スタンプ"
                    automation:AutomationProperties.Name="スタンプ注釈を追加"
                    Click="OnFloatingStampClicked" />
          </StackPanel>
        </Border>
        <Border x:Name="LoadingOverlay"
                IsVisible="False"
                Background="#88000000"
                Opacity="0">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
            </Transitions>
          </Border.Transitions>
          <Border HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Padding="12"
                  CornerRadius="8"
                  Background="{DynamicResource BgPanel2Brush}">
            <StackPanel Spacing="8">
              <ProgressBar IsIndeterminate="True" Width="180" />
              <TextBlock x:Name="LoadingTextBlock"
                         Text="読み込み中..."
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
          </Border>
        </Border>
        <Border x:Name="DragDropOverlay"
                IsVisible="False"
                Background="#66000000">
          <Border HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Padding="16"
                  CornerRadius="10"
                  BorderBrush="{DynamicResource AccentBrush}"
                  BorderThickness="2"
                  Background="#88000000">
            <TextBlock x:Name="DragDropHintTextBlock"
                       Text="ここにドロップ"
                       FontSize="18"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
          </Border>
        </Border>
        <Border x:Name="SplashOverlay"
                IsVisible="True"
                Opacity="1"
                Background="{DynamicResource BgDarkBrush}">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.3" />
            </Transitions>
          </Border.Transitions>
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="10">
            <TextBlock x:Name="SplashTitleTextBlock"
                       Text="AcroPDF"
                       FontSize="28"
                       Foreground="{DynamicResource AccentBrush}" />
            <ProgressBar IsIndeterminate="True" Width="220" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Column="2"
              Background="{DynamicResource BgPanelBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1,0,0,0">
        <Grid RowDefinitions="Auto"
              Margin="8">
          <StackPanel Margin="0,10,0,0"
                      Spacing="2">
            <TextBlock Text="ファイル情報"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock x:Name="FileInfoTextBlock"
                       Foreground="{DynamicResource TextDimBrush}" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="4"
            Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0">
      <Grid Margin="8,2"
            ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*">
        <TextBlock x:Name="ReadyStatusTextBlock"
                   Foreground="{DynamicResource AccentBrush}"
                   Text="● 準備完了" />
        <TextBlock x:Name="FileStatusTextBlock"
                   Grid.Column="1"
                   Margin="12,0,0,0"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock x:Name="PageStatusTextBlock"
                   Grid.Column="2"
                   Margin="12,0,0,0"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock x:Name="ZoomStatusTextBlock"
                   Grid.Column="3"
                   Margin="12,0,0,0"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock x:Name="MouseStatusTextBlock"
                   Grid.Column="4"
                   Margin="12,0,0,0"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock x:Name="PlatformStatusTextBlock"
                   Grid.Column="5"
                   HorizontalAlignment="Right"
                   Foreground="{DynamicResource TextDimBrush}" />
      </Grid>
    </Border>
  </Grid>
</Window>
